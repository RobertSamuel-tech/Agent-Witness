# PostgreSQL connection string for the Aurora PostgreSQL cluster, e.g.
# postgres://user:password@host:5432/database
DATABASE_URL=

# OpenRouter API key used to generate embeddings via the OpenAI-compatible
# OpenRouter API (https://openrouter.ai/api/v1).
# Optional: if missing or unreachable, a deterministic local fallback
# embedding is used instead (degrades semantic search quality).
OPENROUTER_API_KEY=

# Optional. Sent as the HTTP-Referer header on OpenRouter requests
# (used by OpenRouter for attribution/rankings).
OPENROUTER_SITE_URL=

# Optional. Sent as the X-Title header on OpenRouter requests.
OPENROUTER_APP_NAME=AgentWitness

# Optional. Embedding model id passed to OpenRouter. Must produce
# 1536-dimension vectors to match the agent_actions.embedding column.
# Defaults to text-embedding-3-small.
EMBEDDING_MODEL=

# Shared secret required via the x-bootstrap-token header to call
# POST /api/bootstrap. Must be set to enable bootstrap in any environment.
BOOTSTRAP_TOKEN=
